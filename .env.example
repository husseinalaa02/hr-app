# ─── App Settings ─────────────────────────────────────────────────────────────
VITE_DEFAULT_COMPANY=AFAQ ALFIKER

# Set to "true" to run the app in demo mode (uses local IndexedDB, no Supabase required)
VITE_DEMO_MODE=false

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ─── Vercel API Base URL ──────────────────────────────────────────────────────
# Required for native iOS/Android (Capacitor) builds to reach Vercel serverless endpoints.
# Set to your production Vercel URL (no trailing slash). Leave blank for web-only.
VITE_API_BASE_URL=https://your-app.vercel.app

# ─── Geofence (optional) ──────────────────────────────────────────────────────
# Set your office GPS coordinates to enable location-based check-in enforcement.
# Leave VITE_OFFICE_LAT and VITE_OFFICE_LNG blank (or remove them) to disable geofencing.
# VITE_OFFICE_RADIUS_M: allowed radius in metres (default: 100)
VITE_OFFICE_LAT=
VITE_OFFICE_LNG=
VITE_OFFICE_RADIUS_M=100

# ─── Late check-in grace period (optional) ────────────────────────────────────
# Minutes after shift start before a check-in is flagged as "Late". Default: 15.
VITE_LATE_GRACE_MINUTES=15

# ─── Server-side only (set in Vercel Dashboard, never here) ───────────────────
# These are used by Vercel serverless API routes (/api/*).
# Add them via: Vercel → Project → Settings → Environment Variables
# NEVER put real values for these in any file that gets committed.
#
# SUPABASE_URL=https://your-project-id.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# DEFAULT_COMPANY=AFAQ ALFIKER
#
# FRONTEND_URL — your production frontend URL, used for CORS allow-list.
# Example: https://your-app.vercel.app
# (VERCEL_URL is set automatically by Vercel for preview deployments)
# FRONTEND_URL=https://your-app.vercel.app
