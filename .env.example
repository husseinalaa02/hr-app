# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── ERPNext / API Backend ────────────────────────────────────────────────────
# Base URL for server-side API routes (migrate-auth, set-role, create-employee)
VITE_API_BASE_URL=https://your-api-domain.com

# ─── App Config ───────────────────────────────────────────────────────────────
VITE_DEFAULT_COMPANY=AFAQ ALFIKER

# ─── Demo Mode ────────────────────────────────────────────────────────────────
# Set to "true" to enable the offline Dexie demo (any password works).
# Must be "false" in production — enforced in src/main.jsx.
VITE_DEMO_MODE=false
