VITE_ERPNEXT_URL=http://localhost:8080
VITE_API_KEY=your_api_key
VITE_API_SECRET=your_api_secret
VITE_DEFAULT_COMPANY=Afaq Al-Fiker

# Geofence — set your office coordinates to enable location-based check-in.
# Leave blank (or remove) to disable geofencing entirely.
VITE_OFFICE_LAT=33.3152
VITE_OFFICE_LNG=44.3661
VITE_OFFICE_RADIUS_M=100
# VITE_GEOFENCE_ENABLED=false

# ─── Supabase (shared multi-user backend) ────────────────────────────────────
# Set these to enable Supabase mode (overrides DEMO_MODE IndexedDB)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
